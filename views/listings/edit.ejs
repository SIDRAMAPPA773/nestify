<% layout('layouts/boilerplate') %>
<body style="text-align: center;">
    <h3><b>Edit Listing</b> </h3>
   <div class="row mt-3">
    <div class="col-md-8 offset-md-2">
         <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation">
       <div class="mb-3">
        <label for="Title"> Edit Title:</label><br/>
            <input type="text" name="listing[title]" value="<%= listing.title %>" placeholder="Title" class="form-control" required/>
          <div class="invalid-feedback"> Please valid Title</div>
        </div>
    
       
       <div class="mb-3">
        <label for="imageurl"> Edit Image URL:</label><br/>
            <input type="text" name="listing[imageUrl]" value="<%= listing.image.url %>" placeholder="Image URL" class="form-control" required/>
            <div class="invalid-feedback"> Please Provide a Valid Description</div>
        </div>
     

        <div class="mb-3">
            <label for="Description"> Edit Description:</label><br/>
             <textarea name="listing[description]" placeholder="Description" class="form-control" required><%= listing.description %> </textarea>
             <div class="invalid-feedback"> Please Provide a description</div>
            </div>
       
   <div class="row">

       <div class="mb-3 col-md-4">
        <label for="Price"> Edit Price:</label><br/>
        <input type="number" name="listing[price]" value="<%= listing.price %>" placeholder="Price per night" class="form-control" required min="1"/>
         <div class="invalid-feedback"> Please Provide a Valid Price</div>  
    </div>
        
        
      <div class="mb-3 col-md-8">
        <label for="Country"> Edit Country:</label><br/>
         <input type="text" name="listing[country]" value="<%= listing.country %>" placeholder="Country" class="form-control" required/>
          <div class="invalid-feedback"> Please Provide a Valid Country Name</div>
        </div>

   </div>
   
      <div class="mb-3 ">
        <label for="Location"> Edit Location:</label><br/>
        <input type="text" name="listing[location]" value="<%= listing.location %>" placeholder="Location" class="form-control" required/>
        <div class="invalid-feedback"> Please provide a valid location </div>   
    </div> 
     
       <button class="btn btn-dark edit-btn mt-3" type="submit">Update Listing</button>
    </form>
    </div>
   </div>
</body>
<!-- </html> -->