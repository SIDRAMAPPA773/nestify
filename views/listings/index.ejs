<% layout('layouts/boilerplate') %>

<div class="container">

  

  <!-- ⚡ FLASH MESSAGE -->
  <% if (success) { %>
    <div id="flash-msg" class="flash-msg">
      <%= success %>
    </div>

    <script>
      const msg = document.getElementById("flash-msg");

      setTimeout(() => msg.classList.add("show"), 100);

      setTimeout(() => {
        msg.classList.remove("show");
        setTimeout(() => msg.remove(), 400);
      }, 3000);
    </script>
  <% } %>

  <!-- FILTERS -->
 <div class="filters-wrapper">
  <div class="filter-chip active" data-category="all">
  &#128293; All
</div>

 

  <div class="filter-chip" data-category="Beach">
    &#127965;&#65039; Beach
  </div>

  <div class="filter-chip" data-category="Mountain">
    &#127956;&#65039; Mountain
  </div>

  <div class="filter-chip" data-category="City">
    &#127961;&#65039; City
  </div>

  <div class="filter-chip" data-category="Camping">
    &#127957;&#65039; Camping
  </div>

  <div class="filter-chip" data-category="Luxury">
    &#128142; Luxury
  </div>

  <div class="filter-chip" data-category="Budget">
    &#128176; Budget
  </div>
  

  <div class="tax-toggle">

  <span class="toggle-label">&#128176; Prices</span>

  <label class="switch">
    <input type="checkbox" id="switchCheckDefault">
    <span class="slider"></span>
  </label>

  <span class="toggle-state">+ GST</span>

</div>

</div>

  <!-- 🏠 LISTINGS -->
  <h4 class="section-title">Explore Stays</h4>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">

    <% listings.forEach(listing => { %>

      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">

         <div class="listing-card"
     data-price="<%= listing.price %>"
     data-category="<%= listing.category %>">

            <!-- IMAGE -->
            <div class="listing-img-wrapper">
              <img src="<%= listing.image.url %>" alt="Listing Image">
            </div>

            <!-- CONTENT -->
            <div class="listing-content">

              <h5 class="listing-title"><%= listing.title %></h5>

              <p class="listing-location">
                &#128205; <%= listing.location %>
              </p>

              <p class="listing-price">
  ₹ 
  <span class="price-value">
    <%= (listing.price || 0).toLocaleString('en-IN') %>
  </span>

  <span>/ night</span>

  <i class="tax-label">&nbsp;&nbsp;+18% GST</i>
</p>
                
            </div>

          </div>

        </a>
      </div>

    <% }) %>

  </div>

  <!-- 🗺️ MAP -->
  <div class="map-section">

    <h4 class="section-title">🗺️ Explore on Map</h4>

    <div id="map"></div>

  </div>

</div>

<!-- 🔥 PASS DATA -->
<script>
  window.listings = <%- JSON.stringify(listings) %>;
</script>

<!-- 🔥 SCRIPTS -->
<script src="/js/indexMap.js"></script>
<script src="/js/filter.js"></script>