
<% layout('layouts/boilerplate') %>
<body>

    <h1>All Listings</h1>
   <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
    <% listings.forEach(listing => { %>
        <a href="/listings/<%= listing._id %>" class="listing-link" style="text-decoration: none; color: inherit;">

            <div class="card col listing-card" >


          <img src="<%= listing.image.url %>" class="card-img-top" alt="Listing_image" style="height:20rem  ;">
         
         <div class="card-img-overlay">Welcome to <%= listing.title %></div> 
         <div class="card-body">
          <p class="card-text"> <b><%=listing.title %></b> <br> Price: &#8377; <%= (listing.price || 0).toLocaleString('en-IN') %>/night
</p>
          
         </div>
    </div>
        </a>

    

        <% }) %>
   </div>
    
</body>
