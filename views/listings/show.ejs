<% layout('layouts/boilerplate') %>

<h3 class="text-center mb-4"><%= listing.title %></h3>

<div class="row">
  <div class="col-md-6 offset-md-3">

    <div class="card shadow listing-card">
      <img src="<%= listing.image.url %>" 
           class="card-img-top" 
           style="height:300px; object-fit:cover;" 
           alt="Listing Image">

      <div class="card-body">
        <ul class="list-unstyled">
          <li><b>Location:</b> <%= listing.location %></li>
          <li><b>Description:</b> <%= listing.description %></li>
          <li><b>Price:</b> ₹<%= listing.price.toLocaleString('en-IN') %>/night</li>
        </ul>
      </div>
    </div>

    <!-- Buttons -->
    <div class="mt-3 d-flex justify-content-between">
      <form action="/listings/<%= listing._id %>/edit" method="GET">
        <button class="btn btn-warning btn-sm">Edit</button>
      </form>

      <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <button type="submit" class="btn btn-danger btn-sm"
          onclick="return confirm('Are you sure?');">
          Delete
        </button>
      </form>
    </div>

    <hr class="my-4">

    <!-- Review Section -->
    <h4>Leave a Review</h4>

    <form class="border p-3 rounded shadow-sm  needs-validation" action="/listings/<%= listing.id %>/reviews" method="POST" novalidate >
      <div class="mb-3">
        <label class="form-label">Rating</label>
        <input type="range" min="1" max="5" 
               class="form-range" name="review[rating]"/>
      </div>

      <div class="mb-3">
        <label class="form-label">Comments</label>
        <textarea name="review[comment]" 
                  class="form-control" rows="3" required></textarea>
                  <div class="invalid-feedback">
                    Please add a Comment
                  </div>
      </div>

      <button class="btn btn-dark btn-sm">Submit</button>
    </form>

  <hr  class="animated-line">
 <br>

  
<h4>All Reviews</h4>

<div class="row">
  <% listing.reviews.forEach(review => { %>
  <div class="card col-5 ms-5 mb-3">
    <div class="card-body mb-2 p-2">
    <h5 class="card-title"> <b>Sidram</b></h5>
    <p><b>Rating:</b> <%= review.rating %> ⭐</p>
    <p><b>Comment:</b> <%= review.comment %></p>

    <form class="mb-3" method="POST" action="/listings/<%=listing._id %>/reviews/<%=review._id %>?_method=DELETE">
      <button type="submit"class="btn btn-small btn-dark "> Delete</button>
    </form>
  </div>
  </div>
<% }) %>
</div>
    
  </div>
</div>