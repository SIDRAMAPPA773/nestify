<% layout('layouts/boilerplate') %>

<h3 style="text-align: center;">Listing Details</h3>
<div class="row">
    <div class="col-8 offset-2">

        <div class="show-card">
            <div class="card" style="width: 18rem;">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="Listing Image">

                <div class="card-body">
                    <div class="card-text">
                        <ul>
                            <li><b>Title:</b> <%= listing.title %></li>
                            <li><b>Location:</b> <%= listing.location %></li>
                            <li><b>Description:</b> <%= listing.description %></li>
                            <li><b>Price:</b> ₹<%= listing.price.toLocaleString('en-IN') %>/night</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="show-btns"> 
            <form action="/listings/<%= listing._id %>/edit" method="GET" style="display:inline;">
            <button class="btn btn-warning btn-sm show-edit-btn">Edit Listing</button>
        </form>
         &nbsp;&nbsp;&nbsp;&nbsp;

        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-danger btn-sm show-delete-btn"
            onclick="return confirm('Are you sure you want to delete this listing?');">
            Delete Listing
            </button>
        </form>
        </div>

    </div>
</div>
